<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="?android:colorBackground">

    <!-- Side Menu -->
    <LinearLayout
        android:id="@+id/sideMenu"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_chat_bot"
        android:padding="16dp"
        android:visibility="gone"
        android:elevation="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/bg_chat_user"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖"
                android:textSize="48sp" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Guest"
                android:textColor="?android:textColorPrimary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvHistoryCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 conversations"
                android:textColor="?android:textColorSecondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_chat_bot"
            android:padding="12dp">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/historyContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </ScrollView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_chat_bot"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnClearAllHistory"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_send_button"
                android:text="🗑️ Clear All"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvApiStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ AI Search"
                android:textColor="#10A37F"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                android:layout_gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main Content -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="?android:colorBackground">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_chat_bot"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:elevation="8dp">

            <Button
                android:id="@+id/btnMenuToggle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_send_button"
                android:text="☰"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="🔍 AI Search"
                android:textColor="?android:textColorPrimary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNewChat"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_send_button"
                android:text="✨ New"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/bg_send_button"
                android:text="⚙️"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- Chat Area (Full Width) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="?android:colorBackground">

            <ScrollView
                android:id="@+id/scrollView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="12dp"
                android:scrollbarStyle="outsideOverlay">

                <LinearLayout
                    android:id="@+id/chatContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:animateLayoutChanges="true" />

            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_chat_bot"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:elevation="4dp">

                <EditText
                    android:id="@+id/inputMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:hint="Type a message..."
                    android:textColorHint="?android:textColorSecondary"
                    android:textColor="?android:textColorPrimary"
                    android:padding="14dp"
                    android:maxLines="4"
                    android:inputType="textMultiLine"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btnSend"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_send_button"
                    android:text="➤"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Preview Area with WebView -->
        <LinearLayout
            android:id="@+id/previewArea"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:orientation="vertical"
            android:background="@drawable/bg_chat_bot"
            android:visibility="gone"
            android:elevation="8dp">

            <!-- Preview Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp"
                android:background="@drawable/bg_chat_bot">

                <TextView
                    android:id="@+id/tvLiveStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="● Live Preview"
                    android:textColor="#10A37F"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/previewType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱 Android"
                    android:textColor="#F59E0B"
                    android:textSize="12sp"
                    android:background="#2D2D3D"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnFloatingPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_send_button"
                    android:text="👁️ Float"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnClosePreview"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_send_button"
                    android:text="✕"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Preview Container -->
            <FrameLayout
                android:id="@+id/previewContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:padding="4dp">

                <WebView
                    android:id="@+id/webPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#1A1A2E" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>